{
  "name": "a-ripple-song/theme",
  "description": "Composer support for the a-ripple-song WordPress theme",
  "license": "GPL-3.0-or-later",
  "type": "wordpress-theme",
  "require": {
    "php": "^8.0",
    "htmlburger/carbon-fields": "^3.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "App/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "require-dev": {
    "humbug/php-scoper": "^0.18.17",
    "phpunit/phpunit": "^11.2"
  },
  "scripts": {
    "scoper:build": "bash bin/build-scoped-vendor.sh",
    "build:dist": "bash bin/build-dist.sh"
  }
}
