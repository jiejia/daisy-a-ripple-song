{
  "name": "jiejia/daisy-a-ripple-song",
  "description": "Composer support for the daisy-a-ripple-song theme",
  "license": "GPL-3.0-or-later",
  "type": "wordpress-theme",
  "require": {
    "php": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "Jiejia\\DaisyARippleSong\\": "src/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "require-dev": {
    "humbug/php-scoper": "^0.18.17",
    "phpunit/phpunit": "^11.2"
  },
  "scripts": {
    "scoper:build": "bash bin/build-scoped-vendor.sh",
    "build:dist": "bash bin/build-dist.sh"
  }
}
